# Files and directories created by pub.
.dart_tool/
.packages
build/
pubspec.lock

# Conventional directory for build outputs.
doc/api/

# Avoid committing pubspec.lock for library packages; see
# https://dart.dev/guides/libraries/private-files#pubspeclock.
# (Keeping committed pubspec.lock for apps, not for libraries.)

# Generated files.
*.g.dart
*.freezed.dart
!**/test/fixtures/**/*.g.dart  # if any test fixtures happen to be .g.dart, keep them.

# Coverage outputs.
coverage/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Local env / secrets (this is a library — should not have any, but defense in depth).
.env
.env.*
!.env.example
